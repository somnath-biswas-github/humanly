# ─────────────────────────────────────────────
#  Humanly — Environment Variables
#  Copy this file to .env and fill in values.
#  Never commit .env to source control.
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# Set automatically by docker-compose.yml.
# Override here if using an external PostgreSQL.
DATABASE_URL=postgresql://humanly:humanly@localhost:5432/humanly

# ── Session ───────────────────────────────────
# Random secret for signing session cookies.
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_a_long_random_string

# ── OpenAI ────────────────────────────────────
# Required. Used for synthetic user generation,
# evaluation verdicts, and report summaries.
OPENAI_API_KEY=sk-...

# ── SendGrid (optional) ───────────────────────
# Required for password reset and email notifications.
# Leave blank to disable email features.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ── Stripe (optional) ─────────────────────────
# Required only if enabling billing features.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Auth (optional) ───────────────────────────
# Google OAuth for social login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn OAuth for social login.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── App ───────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Storage (optional) ────────────────────────
# For cloud object storage (GCS/S3).
# Leave blank to use local disk (/uploads).
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
